# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    { paths: [process.argv[1]] },
  )', __dir__]).strip

platform :ios, '16.0'

prepare_react_native_project!

# 🔥 Required for Firebase static frameworks
$RNFirebaseAsStaticFramework = true
target 'LogisticApp' do
  config = use_native_modules!
  use_modular_headers!


use_react_native!(
  :path => config[:reactNativePath],
  :hermes_enabled => true,
  :fabric_enabled => false,
  :new_arch_enabled => false,
  :app_path => "#{Pod::Config.instance.installation_root}/.."
)

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # 🔥 Fix Xcode 26 fmt crash
    fmt_base = File.join(installer.sandbox.pod_dir('fmt'), 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)

      patched = content
        .gsub(/^#\s*define\s+FMT_USE_CONSTEVAL\s+1\s*$/, '#  define FMT_USE_CONSTEVAL 0')
        .gsub(/^#\s*define\s+FMT_USE_CONSTEVAL\s+FMT_CONSTEVAL\s*$/, '#  define FMT_USE_CONSTEVAL 0')

      if patched != content
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        Pod::UI.puts '✅ Patched fmt/base.h'
      end
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|

        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'

        # 🔥 CRITICAL FIX (non-modular include error)
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        # 🔥 Fix fmt again at build level
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        defs = [defs] unless defs.is_a?(Array)
        defs << 'FMT_USE_CONSTEVAL=0'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

      end
    end
  end
end